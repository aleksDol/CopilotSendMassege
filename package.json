{
  "name": "ai-sales-assistant-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.2.0",
  "pnpm": {
    "overrides": {
      "jiti": "2.6.1"
    }
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @repo/db prisma:generate",
    "db:migrate": "pnpm --filter @repo/db prisma:migrate",
    "db:migrate:deploy": "pnpm --filter @repo/db prisma:migrate:deploy",
    "db:studio": "pnpm --filter @repo/db prisma:studio",
    "db:seed": "pnpm --filter @repo/db prisma:seed"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^8.57.1",
    "prettier": "^3.5.3",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  }
}
