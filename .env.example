# ===== Common =====
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
PORT=4000

# Domain / proxy
APP_DOMAIN=localhost
APP_BASE_URL=http://localhost:3000

# Yandex.Metrica (web). Counter loads with lazyOnload; omitted in dev unless NEXT_PUBLIC_YANDEX_METRIKA_ENABLED=1
NEXT_PUBLIC_YANDEX_METRIKA_ID=108223264
# NEXT_PUBLIC_YANDEX_METRIKA_ENABLED=1

# Top.Mail.Ru counter (lazyOnload). Dev: set NEXT_PUBLIC_TOP_MAIL_RU_ENABLED=1 to test
NEXT_PUBLIC_TOP_MAIL_RU_ID=3752150
# NEXT_PUBLIC_TOP_MAIL_RU_ENABLED=1

SSL_EMAIL=admin@example.com
NGINX_CLIENT_MAX_BODY_SIZE=20m

# ===== Database / cache =====
POSTGRES_DB=ai_sales_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_sales_assistant
REDIS_URL=redis://localhost:6379

# ===== Auth / security =====
# Comma-separated emails with access to /admin (API + UI). Empty = admin disabled.
ADMIN_EMAILS=admin@example.com
JWT_SECRET=replace_with_minimum_32_characters_secret
INTERNAL_API_TOKEN=replace_with_internal_service_token_32_chars
CORS_ORIGIN=http://localhost:3000
EMAIL_CODE_SECRET=replace_with_email_code_secret_32_chars
EMAIL_CODE_TTL_MINUTES=10
EMAIL_CODE_RESEND_COOLDOWN_SECONDS=60
EMAIL_CODE_MAX_ATTEMPTS=5

# ===== Email / SMTP =====
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp_user
SMTP_PASS=smtp_password
SMTP_SECURE=false

# ===== Internal service URLs =====
TELEGRAM_WORKER_URL=http://localhost:8080
API_INTERNAL_URL=http://localhost:4000
TELEGRAM_WORKER_TIMEOUT_MS=15000

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SALES_TELEGRAM_URL=https://t.me/your_manager_username

# ===== AI =====
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_REPLY=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROMPT_VERSION=v1

# ===== Billing / Stripe =====
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_TEAM=price_xxx_team
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===== Telegram =====
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_ENCRYPTION_KEY=32_characters_minimum_secret_key
TELEGRAM_INITIAL_DIALOG_LIMIT=100
TELEGRAM_INITIAL_MESSAGES_PER_DIALOG=50
TELEGRAM_AUTO_SYNC_ENABLED=true
TELEGRAM_AUTO_SYNC_INTERVAL_SECONDS=15
TELEGRAM_AUTO_SYNC_DIALOG_LIMIT=100
TELEGRAM_AUTO_SYNC_MESSAGES_PER_DIALOG=20
TELEGRAM_LIVE_LISTENER_ENABLED=true
TELEGRAM_LIVE_LISTENER_REFRESH_SECONDS=20
TELEGRAM_MIN_SEND_INTERVAL_MS=2000
TELEGRAM_MAX_SENDS_PER_MINUTE=20
TELEGRAM_MAX_SENDS_PER_5_MINUTES=60
TELEGRAM_MAX_NEW_CONVERSATIONS_PER_HOUR=10
TELEGRAM_SYNC_MIN_INTERVAL_SECONDS=30
TELEGRAM_MAX_CONCURRENT_SYNCS_PER_ACCOUNT=1
TELEGRAM_SEND_RETRY_MAX_ATTEMPTS=2
TELEGRAM_SAFETY_MODE_ERROR_THRESHOLD=5
TELEGRAM_SAFETY_MODE_COOLDOWN_MINUTES=30

# ===== Follow-up/dashboard =====
FOLLOW_UP_UNANSWERED_HOURS=24
FOLLOW_UP_WARM_LEAD_HOURS=48
DASHBOARD_ACTIVITY_WINDOW_DAYS=7

# ===== Backup =====
BACKUP_RETENTION_DAYS=7
POSTGRES_BACKUP_INTERVAL_SECONDS=86400

AI_REQUEST_TIMEOUT_MS=12000
AI_MAX_CONTEXT_MESSAGES=20
REDIS_CACHE_TTL=45
AI_WORKER_CONCURRENCY=2
TELEGRAM_WORKER_CONCURRENCY=2

