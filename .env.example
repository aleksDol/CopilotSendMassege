# ===== Common =====
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
PORT=4000

# Domain / proxy
APP_DOMAIN=localhost
APP_BASE_URL=http://localhost:3000
SSL_EMAIL=admin@example.com
NGINX_CLIENT_MAX_BODY_SIZE=20m

# ===== Database / cache =====
POSTGRES_DB=ai_sales_assistant
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_sales_assistant
REDIS_URL=redis://localhost:6379

# ===== Auth / security =====
JWT_SECRET=replace_with_minimum_32_characters_secret
INTERNAL_API_TOKEN=replace_with_internal_service_token_32_chars
CORS_ORIGIN=http://localhost:3000

# ===== Internal service URLs =====
TELEGRAM_WORKER_URL=http://localhost:8080
API_INTERNAL_URL=http://localhost:4000
TELEGRAM_WORKER_TIMEOUT_MS=15000

# ===== Frontend =====
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===== AI =====
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_REPLY=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROMPT_VERSION=v1

# ===== Billing / Stripe =====
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO=price_xxx_pro
STRIPE_PRICE_TEAM=price_xxx_team
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===== Telegram =====
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_ENCRYPTION_KEY=32_characters_minimum_secret_key
TELEGRAM_INITIAL_DIALOG_LIMIT=100
TELEGRAM_INITIAL_MESSAGES_PER_DIALOG=50
TELEGRAM_AUTO_SYNC_ENABLED=true
TELEGRAM_AUTO_SYNC_INTERVAL_SECONDS=15
TELEGRAM_AUTO_SYNC_DIALOG_LIMIT=20
TELEGRAM_AUTO_SYNC_MESSAGES_PER_DIALOG=20

# ===== Follow-up/dashboard =====
FOLLOW_UP_UNANSWERED_HOURS=24
FOLLOW_UP_WARM_LEAD_HOURS=48
DASHBOARD_ACTIVITY_WINDOW_DAYS=7

# ===== Backup =====
BACKUP_RETENTION_DAYS=7
POSTGRES_BACKUP_INTERVAL_SECONDS=86400

AI_REQUEST_TIMEOUT_MS=12000
AI_MAX_CONTEXT_MESSAGES=20
REDIS_CACHE_TTL=45
AI_WORKER_CONCURRENCY=2
TELEGRAM_WORKER_CONCURRENCY=2

