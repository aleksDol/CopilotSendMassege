generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// =========================
/// Enums
/// =========================
enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

enum UsageMetricType {
  AI_SUGGESTION
  AI_TOKEN_INPUT
  AI_TOKEN_OUTPUT
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum EmailAuthCodePurpose {
  LOGIN_2FA
  REGISTER
}

enum ChannelType {
  TELEGRAM
  WHATSAPP
  EMAIL
  OTHER
}

enum ChannelAccountStatus {
  CONNECTING
  ACTIVE
  PAUSED
  ERROR
  DISCONNECTED
}

enum TelegramLoginStatus {
  LOGIN_REQUIRED
  CODE_SENT
  PASSWORD_REQUIRED
  CONNECTED
  RECONNECT_REQUIRED
  LIMITED
  DISABLED
  ERROR
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
}

enum ConversationParticipantRole {
  MEMBER
  ADMIN
  OWNER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  SYSTEM
}

enum MessageType {
  TEXT
  MEDIA
  SERVICE
  CHANNEL_COMMENT
  OTHER
}

enum LeadStatus {
  NEW
  OPEN
  WON
  LOST
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum LeadSource {
  TELEGRAM
  IMPORT
  MANUAL
  API
}

enum LeadEventType {
  STATUS_CHANGED
  STAGE_CHANGED
  SCORE_CHANGED
  OWNER_CHANGED
  NOTE_ADDED
}

enum LeadEventSource {
  USER
  SYSTEM
  AI
}

enum SummaryKind {
  ROLLING
  SNAPSHOT
  HANDOFF
}

enum SuggestionType {
  REPLY
  FOLLOW_UP
  OBJECTION_HANDLING
  REENGAGEMENT
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  SENT
  EXPIRED
}

enum AiSuggestionMode {
  DEFAULT
  SHORTER
  MORE_FRIENDLY
  MORE_SALES
  HANDLE_OBJECTION
}

enum AiRunType {
  REPLY_GENERATION
  SUGGESTION
  SUMMARY
  CLASSIFICATION
  EXTRACTION
  FOLLOW_UP
}

enum AiRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum TaskType {
  FOLLOW_UP
  CALL
  MESSAGE
  REVIEW
  MANUAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskSource {
  MANUAL
  SYSTEM
  AI
}

enum KnowledgeKind {
  FAQ
  PRODUCT
  POLICY
  SCRIPT
  OTHER
}

/// =========================
/// LeadRadar (isolated module)
/// NOTE: These enums/models are separate from existing Lead/LeadEvent.
/// =========================
enum LeadRadarLeadStatus {
  new
  reviewed
  hot
  contacted
  replied
  qualified
  won
  lost
  ignored
  spam
}

enum LeadRadarMatchType {
  contains
  exact
  regex
}

enum LeadRadarCategory {
  bot
  website
  ai
  mvp
  automation
  general
}

/// =========================
/// Company / User layer
/// =========================
model Company {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  timezone  String   @default("UTC")
  defaultReplyPolicy Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  subscriptions   Subscription[]
  usageRecords    UsageRecord[]
  invites         TeamInvite[]
  channelAccounts ChannelAccount[]
  participants    Participant[]
  conversations   Conversation[]
  messages        Message[]
  leads           Lead[]
  aiSuggestions   AiSuggestion[]
  aiRuns          AiRun[]
  tasks           Task[]
  knowledgeItems  KnowledgeItem[]
  replyPolicy     ReplyPolicy?
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  companyId    String    @db.Uuid
  email        String    @unique
  passwordHash String
  fullName     String
  role         UserRole  @default(MEMBER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company                Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdChannelAccounts ChannelAccount[] @relation("ChannelAccountCreatedBy")
  assignedConversations  Conversation[]
  ownedLeads             Lead[]          @relation("LeadOwner")
  leadEvents             LeadEvent[]     @relation("LeadEventCreatedBy")
  assignedTasks          Task[]          @relation("TaskAssignedUser")
  knowledgeItemsCreated  KnowledgeItem[] @relation("KnowledgeItemCreatedBy")
  aiSuggestionsForUser   AiSuggestion[]  @relation("AiSuggestionCreatedForUser")
  createdInvites         TeamInvite[]    @relation("InviteCreatedBy")

  // LeadRadar (isolated module) relations
  leadRadarSources          LeadRadarSource[]
  leadRadarKeywords         LeadRadarKeyword[]
  leadRadarNegativeKeywords LeadRadarNegativeKeyword[]
  leadRadarLeads            LeadRadarLead[]
  leadRadarSettings         LeadRadarSettings[]

  @@index([companyId])
  @@index([companyId, role])
}

model EmailAuthCode {
  id             String               @id @default(uuid()) @db.Uuid
  email          String
  codeHash       String
  challengeId    String               @unique
  purpose        EmailAuthCodePurpose
  expiresAt      DateTime
  usedAt         DateTime?
  attemptCount   Int                  @default(0)
  maxAttempts    Int
  codeSentCount  Int                  @default(1)
  lastSentAt     DateTime
  ipAddress      String?
  userAgent      String?
  payload        Json?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([email, purpose, createdAt(sort: Desc)])
  @@index([challengeId, purpose, usedAt])
  @@index([expiresAt])
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  companyId            String             @db.Uuid
  plan                 Plan
  status               SubscriptionStatus @default(TRIALING)
  trialStartedAt       DateTime?
  trialEndsAt          DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model UsageRecord {
  id          String          @id @default(uuid()) @db.Uuid
  companyId   String          @db.Uuid
  metricType  UsageMetricType
  quantity    Int
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime        @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, metricType, periodStart])
  @@index([companyId, createdAt(sort: Desc)])
}

model TeamInvite {
  id            String   @id @default(uuid()) @db.Uuid
  companyId     String   @db.Uuid
  email         String
  token         String   @unique
  role          UserRole @default(MEMBER)
  invitedByUserId String? @db.Uuid
  expiresAt     DateTime
  acceptedAt    DateTime?
  createdAt     DateTime @default(now())

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedByUser User?   @relation("InviteCreatedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, email, acceptedAt])
}

/// =========================
/// Channel abstraction layer
/// =========================
model ChannelAccount {
  id                String               @id @default(uuid()) @db.Uuid
  companyId         String               @db.Uuid
  channelType       ChannelType
  displayName       String
  externalAccountId String
  status            ChannelAccountStatus @default(ACTIVE)
  isPrimary         Boolean              @default(false)
  createdByUserId   String?              @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  company       Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User?         @relation("ChannelAccountCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  telegram      TelegramAccount?
  participants  Participant[]
  conversations Conversation[]

  @@unique([companyId, channelType, externalAccountId])
  @@index([companyId, status])
  @@index([companyId, isPrimary])
}

model TelegramAccount {
  id                   String              @id @default(uuid()) @db.Uuid
  channelAccountId     String              @unique @db.Uuid
  phone                String?
  telegramUserId       String?
  username             String?
  sessionDataEncrypted String?
  apiDcId              Int?
  authPhoneCodeHash    String?
  loginStatus          TelegramLoginStatus @default(LOGIN_REQUIRED)
  lastSyncAt           DateTime?
  lastEventAt          DateTime?
  errorMessage         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  channelAccount ChannelAccount @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)

  // LeadRadar (isolated module) relations
  leadRadarSources          LeadRadarSource[]
  leadRadarKeywords         LeadRadarKeyword[]
  leadRadarNegativeKeywords LeadRadarNegativeKeyword[]
  leadRadarLeads            LeadRadarLead[]
  leadRadarSettings         LeadRadarSettings[]
  leadRadarAuthorProfileCaches LeadRadarAuthorProfileCache[]

  @@index([telegramUserId])
  @@index([loginStatus])
}

/// =========================
/// Conversation layer (raw records)
/// =========================
model Participant {
  id                    String   @id @default(uuid()) @db.Uuid
  companyId             String   @db.Uuid
  channelAccountId      String   @db.Uuid
  externalParticipantId String
  username              String?
  fullName              String?
  firstName             String?
  lastName              String?
  phone                 String?
  isSelf                Boolean  @default(false)
  metadata              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  company                  Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channelAccount           ChannelAccount            @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  conversationParticipants ConversationParticipant[]
  messages                 Message[]

  @@unique([channelAccountId, externalParticipantId])
  @@index([companyId])
  @@index([channelAccountId])
}

model Conversation {
  id                     String           @id @default(uuid()) @db.Uuid
  companyId              String           @db.Uuid
  channelAccountId       String           @db.Uuid
  externalConversationId String
  conversationType       ConversationType
  title                  String?
  isArchived             Boolean          @default(false)
  assignedUserId         String?          @db.Uuid
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  company                  Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  channelAccount           ChannelAccount             @relation(fields: [channelAccountId], references: [id], onDelete: Cascade)
  assignedUser             User?                      @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  participants             ConversationParticipant[]
  messages                 Message[]
  state                    ConversationState?
  lead                     Lead?
  summaries                ConversationSummary[]
  aiSuggestions            AiSuggestion[]
  aiRuns                   AiRun[]
  tasks                    Task[]

  @@unique([channelAccountId, externalConversationId])
  @@index([companyId, isArchived])
  @@index([companyId, updatedAt(sort: Desc)])
  @@index([assignedUserId])
}

model ConversationParticipant {
  id             String                      @id @default(uuid()) @db.Uuid
  conversationId String                      @db.Uuid
  participantId  String                      @db.Uuid
  role           ConversationParticipantRole @default(MEMBER)
  joinedAt       DateTime                    @default(now())
  leftAt         DateTime?
  createdAt      DateTime                    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  participant  Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([conversationId, participantId])
  @@index([participantId])
}

model Message {
  id                       String           @id @default(uuid()) @db.Uuid
  companyId                String           @db.Uuid
  conversationId           String           @db.Uuid
  participantId            String?          @db.Uuid
  externalMessageId        String
  replyToExternalMessageId String?
  direction                MessageDirection
  messageType              MessageType
  text                     String?
  normalizedText           String?
  sentAt                   DateTime
  editedAt                 DateTime?
  isDeleted                Boolean          @default(false)
  hasAttachment            Boolean          @default(false)
  relatedChannelId         String?          @map("related_channel_id")
  relatedPostId            String?          @map("related_post_id")
  contextPreview           String?          @map("context_preview")
  dedupeKey                String?          @map("dedupe_key")
  rawPayload               Json?
  createdAt                DateTime         @default(now())

  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation          Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  participant           Participant?         @relation(fields: [participantId], references: [id], onDelete: SetNull)
  triggerAiSuggestions  AiSuggestion[]      @relation("AiSuggestionTriggerMessage")
  sentAiSuggestions     AiSuggestion[]      @relation("AiSuggestionSentMessage")
  aiRuns                AiRun[]
  stateAsLastMessage    ConversationState[] @relation("ConversationStateLastMessage")
  coveredBySummaries    ConversationSummary[]

  @@unique([conversationId, externalMessageId])
  @@index([conversationId, sentAt(sort: Desc)])
  @@index([companyId, sentAt(sort: Desc)])
  @@index([participantId])
  @@unique([dedupeKey], map: "Message_dedupe_key_key")
}

/// =========================
/// Conversation state layer
/// =========================
model ConversationState {
  id                           String          @id @default(uuid()) @db.Uuid
  conversationId               String          @unique @db.Uuid
  lastMessageId                String?         @db.Uuid
  lastMessageAt                DateTime?
  lastMessagePreview           String?
  lastInboundAt                DateTime?
  lastOutboundAt               DateTime?
  unansweredClientMessageCount Int             @default(0)
  isWaitingForReply            Boolean         @default(false)
  leadStatus                   LeadStatus      @default(NEW)
  leadStage                    LeadStage       @default(NEW)
  leadScore                    Int             @default(0)
  leadTemperature              LeadTemperature @default(COLD)
  lastClientIntent             String?
  nextRecommendedAction        String?
  followUpDueAt                DateTime?
  riskFlags                    Json?
  summaryVersion               Int             @default(0)
  stateVersion                 Int             @default(1)
  updatedAt                    DateTime        @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastMessage  Message?     @relation("ConversationStateLastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)

  @@index([lastMessageAt(sort: Desc)])
  @@index([followUpDueAt])
  @@index([leadStatus, leadStage])
}

/// =========================
/// Lead layer
/// =========================
model Lead {
  id             String       @id @default(uuid()) @db.Uuid
  companyId      String       @db.Uuid
  conversationId String       @unique @db.Uuid
  ownerUserId    String?      @db.Uuid
  status         LeadStatus   @default(OPEN)
  stage          LeadStage    @default(NEW)
  score          Int          @default(0)
  source         LeadSource   @default(TELEGRAM)
  estimatedValue Decimal?     @db.Decimal(12, 2)
  currency       String       @default("USD") @db.VarChar(3)
  lostReason     String?
  wonAt          DateTime?
  lostAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  ownerUser    User?       @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  events       LeadEvent[]
  tasks        Task[]

  @@index([companyId, status, stage])
  @@index([companyId, stage])
  @@index([ownerUserId])
}

model LeadEvent {
  id              String          @id @default(uuid()) @db.Uuid
  leadId          String          @db.Uuid
  eventType       LeadEventType
  oldValue        Json?
  newValue        Json?
  source          LeadEventSource @default(SYSTEM)
  createdByUserId String?         @db.Uuid
  createdAt       DateTime        @default(now())

  lead          Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdByUser User? @relation("LeadEventCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt(sort: Desc)])
  @@index([createdByUserId])
}

/// =========================
/// AI memory / artifacts
/// =========================
model ConversationSummary {
  id                     String      @id @default(uuid()) @db.Uuid
  conversationId         String      @db.Uuid
  summaryText            String
  coverageUntilMessageId String?     @db.Uuid
  summaryKind            SummaryKind @default(ROLLING)
  model                  String?
  promptVersion          String?
  createdAt              DateTime    @default(now())

  conversation         Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  coverageUntilMessage Message?     @relation(fields: [coverageUntilMessageId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt(sort: Desc)])
}

model AiSuggestion {
  id               String           @id @default(uuid()) @db.Uuid
  companyId        String           @db.Uuid
  conversationId   String           @db.Uuid
  triggerMessageId String?          @db.Uuid
  suggestionType   SuggestionType
  mode             AiSuggestionMode @default(DEFAULT)
  status           SuggestionStatus @default(PENDING)
  model            String?
  promptHash       String?
  inputContext     Json?
  suggestionText   String
  confidence       Decimal?         @db.Decimal(5, 4)
  createdForUserId String?          @db.Uuid
  acceptedAt       DateTime?
  rejectedAt       DateTime?
  editedBeforeSend Boolean          @default(false)
  sentMessageId    String?          @db.Uuid
  createdAt        DateTime         @default(now())

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  triggerMessage  Message?      @relation("AiSuggestionTriggerMessage", fields: [triggerMessageId], references: [id], onDelete: SetNull)
  createdForUser  User?         @relation("AiSuggestionCreatedForUser", fields: [createdForUserId], references: [id], onDelete: SetNull)
  sentMessage     Message?      @relation("AiSuggestionSentMessage", fields: [sentMessageId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([conversationId, status, createdAt(sort: Desc)])
  @@index([conversationId, mode, createdAt(sort: Desc)])
  @@index([createdForUserId])
}

model AiRun {
  id           String      @id @default(uuid()) @db.Uuid
  companyId    String      @db.Uuid
  conversationId String?   @db.Uuid
  messageId    String?     @db.Uuid
  runType      AiRunType
  provider     String
  model        String
  status       AiRunStatus @default(QUEUED)
  inputTokens  Int         @default(0)
  outputTokens Int         @default(0)
  cachedTokens Int         @default(0)
  latencyMs    Int?
  costUsd      Decimal?    @db.Decimal(10, 6)
  promptVersion String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime    @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([messageId])
}

/// =========================
/// Tasks
/// =========================
model Task {
  id             String       @id @default(uuid()) @db.Uuid
  companyId      String       @db.Uuid
  conversationId String?      @db.Uuid
  leadId         String?      @db.Uuid
  assignedUserId String?      @db.Uuid
  taskType       TaskType
  title          String
  description    String?
  status         TaskStatus   @default(OPEN)
  priority       TaskPriority @default(MEDIUM)
  dueAt          DateTime?
  source         TaskSource   @default(SYSTEM)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  completedAt    DateTime?

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  lead         Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  assignedUser User?         @relation("TaskAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status, dueAt])
  @@index([companyId, status])
  @@index([assignedUserId, status])
  @@index([leadId])
  @@index([conversationId])
}

/// =========================
/// Knowledge and policies
/// =========================
model KnowledgeItem {
  id              String        @id @default(uuid()) @db.Uuid
  companyId       String        @db.Uuid
  kind            KnowledgeKind
  title           String
  content         String
  isActive        Boolean       @default(true)
  priority        Int           @default(0)
  version         Int           @default(1)
  createdByUserId String?       @db.Uuid
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdByUser User?   @relation("KnowledgeItemCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([companyId, kind, isActive])
  @@index([companyId, updatedAt(sort: Desc)])
}

model ReplyPolicy {
  id                String   @id @default(uuid()) @db.Uuid
  companyId         String   @db.Uuid
  toneRules         Json?
  pricingRules      Json?
  discountRules     Json?
  forbiddenPromises Json?
  forbiddenTopics   Json?
  humanHandoffRules Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId])
}

/// =========================
/// LeadRadar tables
/// - account-scoped by (user_id, telegram_account_id)
/// - stored independently from existing Lead tables
/// =========================
model LeadRadarSource {
  id                String   @id @default(uuid()) @db.Uuid @map("id")
  userId            String   @db.Uuid @map("user_id")
  telegramAccountId String   @db.Uuid @map("telegram_account_id")
  telegramChatId    String   @map("telegram_chat_id")
  chatTitle         String?  @map("chat_title")
  chatType          String?  @map("chat_type")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  @@unique([telegramAccountId, telegramChatId], map: "lead_sources_telegram_account_id_telegram_chat_id_key")
  @@index([userId], map: "lead_sources_user_id_idx")
  @@index([telegramAccountId], map: "lead_sources_telegram_account_id_idx")
  @@map("lead_sources")
}

model LeadRadarKeyword {
  id                String             @id @default(uuid()) @db.Uuid @map("id")
  userId            String             @db.Uuid @map("user_id")
  telegramAccountId String             @db.Uuid @map("telegram_account_id")
  keyword           String             @map("keyword")
  target            String             @default("message") @map("target")
  matchType         LeadRadarMatchType @map("match_type")
  category          LeadRadarCategory  @map("category")
  priority          Int                @default(0) @map("priority")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  @@index([telegramAccountId], map: "lead_keywords_telegram_account_id_idx")
  @@index([isActive], map: "lead_keywords_is_active_idx")
  @@map("lead_keywords")
}

model LeadRadarAuthorProfileCache {
  id                       String   @id @default(cuid()) @map("id")
  telegramAccountId        String   @db.Uuid @map("telegram_account_id")
  telegramUserId           String   @map("telegram_user_id")
  username                 String?  @map("username")
  displayName              String?  @map("display_name")
  bio                      String?  @map("bio")
  linkedChannelId          String?  @map("linked_channel_id")
  linkedChannelUsername    String?  @map("linked_channel_username")
  linkedChannelTitle       String?  @map("linked_channel_title")
  linkedChannelDescription String?  @map("linked_channel_description")
  rawProfileJson           Json?    @map("raw_profile_json")
  fetchedAt                DateTime @map("fetched_at")
  expiresAt                DateTime @map("expires_at")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  @@unique([telegramAccountId, telegramUserId], map: "lead_author_profile_cache_tg_acc_user_key")
  @@index([telegramAccountId, expiresAt], map: "lead_author_profile_cache_tg_acc_expires_idx")
  @@index([username], map: "lead_author_profile_cache_username_idx")
  @@map("lead_author_profile_cache")
}

model LeadRadarNegativeKeyword {
  id                String   @id @default(uuid()) @db.Uuid @map("id")
  userId            String   @db.Uuid @map("user_id")
  telegramAccountId String   @db.Uuid @map("telegram_account_id")
  phrase            String   @map("phrase")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  @@index([telegramAccountId], map: "lead_negative_keywords_telegram_account_id_idx")
  @@index([isActive], map: "lead_negative_keywords_is_active_idx")
  @@map("lead_negative_keywords")
}

model LeadRadarLead {
  id                String              @id @default(uuid()) @db.Uuid @map("id")
  userId            String              @db.Uuid @map("user_id")
  telegramAccountId String              @db.Uuid @map("telegram_account_id")
  telegramUserId    String?             @map("telegram_user_id")
  username          String?             @map("username")
  displayName       String?             @map("display_name")
  chatId            String              @map("chat_id")
  chatTitle         String?             @map("chat_title")
  sourceType        String?             @map("source_type")
  relatedPostId     String?             @map("related_post_id")
  contextPreview    String?             @map("context_preview")
  messageId         String              @map("message_id")
  messageText       String?             @map("message_text")
  messageDate       DateTime            @map("message_date")
  matchedKeywords   Json                @map("matched_keywords_json")
  score             Int                 @default(0) @map("score")
  leadType          String?             @map("lead_type")
  status            LeadRadarLeadStatus @default(new) @map("status")
  notes             String?             @map("notes")
  contactedAt       DateTime?           @map("contacted_at")
  /// Last activity time for this lead (updated on multi-chat merge).
  lastSeenAt        DateTime?           @map("last_seen_at")
  /// Extra chats where the same Telegram user matched (same sender id/username only).
  multiChatSourcesJson Json             @default("[]") @map("multi_chat_sources_json")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  messageContext LeadRadarMessageContext?
  events         LeadRadarEvent[]

  @@unique([telegramAccountId, chatId, messageId], map: "leads_telegram_account_id_chat_id_message_id_key")
  @@index([telegramAccountId, status], map: "leads_telegram_account_id_status_idx")
  @@index([telegramAccountId, createdAt(sort: Desc)], map: "leads_telegram_account_id_created_at_desc_idx")
  @@index([telegramAccountId, chatId], map: "leads_telegram_account_id_chat_id_idx")
  @@index([telegramAccountId, username], map: "leads_telegram_account_id_username_idx")
  @@index([telegramAccountId, telegramUserId, createdAt(sort: Desc)], map: "leads_telegram_account_id_tg_user_created_idx")
  @@map("leads")
}

model LeadRadarMessageContext {
  id             String   @id @default(uuid()) @db.Uuid @map("id")
  leadId         String   @db.Uuid @unique @map("lead_id")
  beforeMessages Json     @map("before_messages_json")
  afterMessages  Json     @map("after_messages_json")
  createdAt      DateTime @default(now()) @map("created_at")

  lead LeadRadarLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_message_context")
}

model LeadRadarEvent {
  id        String   @id @default(uuid()) @db.Uuid @map("id")
  leadId    String   @db.Uuid @map("lead_id")
  eventType String   @map("event_type")
  oldStatus String?  @map("old_status")
  newStatus String?  @map("new_status")
  comment   String?  @map("comment")
  createdBy String?  @db.Uuid @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  lead LeadRadarLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId], map: "lead_events_lead_id_idx")
  @@map("lead_events")
}

model LeadRadarSettings {
  id                  String   @id @default(uuid()) @db.Uuid @map("id")
  userId              String   @db.Uuid @map("user_id")
  telegramAccountId   String   @db.Uuid @map("telegram_account_id")
  isEnabled           Boolean  @default(true) @map("is_enabled")
  authorProfileMatchingEnabled Boolean @default(false) @map("author_profile_matching_enabled")
  minScoreThreshold   Int      @default(0) @map("min_score_threshold")
  storeContextEnabled Boolean  @default(false) @map("store_context_enabled")
  contextBeforeCount  Int      @default(0) @map("context_before_count")
  contextAfterCount   Int      @default(0) @map("context_after_count")
  dedupeWindowHours   Int      @default(24) @map("dedupe_window_hours")
  coldFirstTouchPlaybook String? @map("cold_first_touch_playbook")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user            User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  telegramAccount TelegramAccount @relation(fields: [telegramAccountId], references: [id], onDelete: Restrict)

  @@unique([telegramAccountId], map: "lead_settings_telegram_account_id_key")
  @@index([userId], map: "lead_settings_user_id_idx")
  @@map("lead_settings")
}
